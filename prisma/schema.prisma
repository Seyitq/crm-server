generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite: no enums — using String fields
// Role: "ADMIN" | "SALES_CONSULTANT"
// UnitStatus: "AVAILABLE" | "RESERVED" | "SOLD"
// DepositStatus: "ACTIVE" | "EXPIRED" | "CANCELLED" | "CONVERTED"
// PaymentType: "CASH" | "BANK_LOAN" | "INSTALLMENT"
// InstallmentStatus: "PENDING" | "PAID" | "OVERDUE"
// NotificationType: "DEPOSIT_EXPIRY" | "OVERDUE_INSTALLMENT" | "BACKUP_FAILURE" | "UNIT_LOCK_CONFLICT" | "SYSTEM"

// ==================== MODELS ====================

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         String   @default("SALES_CONSULTANT")
  phone        String?
  email        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectAssignments   UserProject[]
  deposits             Deposit[]
  sales                Sale[]
  customerNotes        CustomerNote[]
  customerInteractions CustomerInteraction[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  unitLocks            UnitLock[]
  refreshTokens        RefreshToken[]
  tasksAssigned        Task[]  @relation("TaskAssignee")
  tasksCreated         Task[]  @relation("TaskCreator")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blocks            Block[]
  userAssignments   UserProject[]
  contractTemplates ContractTemplate[]
}

model UserProject {
  userId     String
  projectId  String
  assignedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model Block {
  id        String   @id @default(cuid())
  name      String
  projectId String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  floors  Floor[]
  units   Unit[]
}

model Floor {
  id           String  @id @default(cuid())
  number       Int
  label        String? // e.g. "Zemin Kat", "1. Kat"
  blockId      String
  svgContent   String?
  planImageUrl String? // uploaded floor plan image path
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  block      Block           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  units      Unit[]
  planAreas  FloorPlanArea[]

  @@unique([blockId, number])
}

model Unit {
  id          String     @id @default(cuid())
  code        String     // e.g. "D-101" — must match SVG polygon id
  floorId     String
  blockId     String
  type        String?    // e.g. "2+1", "3+1"
  area        Decimal?
  price       Decimal
  status      String     @default("AVAILABLE")
  version     Int        @default(0)
  notes       String?
  orientation String?    // compass direction: "N" | "S" | "E" | "W" | "NE" | "NW" | "SE" | "SW"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  floor     Floor          @relation(fields: [floorId], references: [id], onDelete: Cascade)
  block     Block          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  deposits  Deposit[]
  sales     Sale[]
  locks     UnitLock[]
  planAreas FloorPlanArea[]

  @@unique([code, blockId])
  @@index([floorId])
  @@index([blockId])
  @@index([status])
}

model Customer {
  id        String   @id @default(cuid())
  tcNo      String   @unique
  firstName String
  lastName  String
  phone     String
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes        CustomerNote[]
  interactions CustomerInteraction[]
  deposits     Deposit[]
  sales        Sale[]
  tasks        Task[]

  @@index([lastName, firstName])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId])
}

model CustomerInteraction {
  id          String   @id @default(cuid())
  customerId  String
  userId      String
  type        String
  description String
  date        DateTime
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([date])
}

model Deposit {
  id           String        @id @default(cuid())
  unitId       String
  customerId   String
  consultantId String
  amount       Decimal
  depositDate  DateTime      @default(now())
  expiresAt    DateTime
  validityDays Int
  status       String        @default("ACTIVE")
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  unit       Unit     @relation(fields: [unitId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])
  consultant User     @relation(fields: [consultantId], references: [id])

  @@index([unitId])
  @@index([status])
  @@index([expiresAt])
}

model Sale {
  id           String      @id @default(cuid())
  unitId       String
  customerId   String
  consultantId String
  totalPrice   Decimal
  saleDate     DateTime    @default(now())
  paymentType  String
  bankName     String?
  loanAmount   Decimal?
  approvalDate DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  consultant   User          @relation(fields: [consultantId], references: [id])
  installments Installment[]
  contracts    Contract[]

  @@index([unitId])
  @@index([customerId])
  @@index([consultantId])
  @@index([saleDate])
}

model Installment {
  id         String            @id @default(cuid())
  saleId     String
  amount     Decimal
  dueDate    DateTime
  paidDate   DateTime?
  paidAmount Decimal?
  status     String            @default("PENDING")
  order      Int
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([dueDate])
  @@index([status])
}

model ContractTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String
  projectId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id])
  contracts Contract[]
}

model Contract {
  id          String   @id @default(cuid())
  saleId      String
  templateId  String
  pdfPath     String
  generatedAt DateTime @default(now())

  sale     Sale             @relation(fields: [saleId], references: [id])
  template ContractTemplate @relation(fields: [templateId], references: [id])

  @@index([saleId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  beforeState String?
  afterState  String?
  ipAddress   String?
  description String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              String
  title             String
  message           String
  isRead            Boolean          @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model UnitLock {
  id        String   @id @default(cuid())
  unitId    String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FloorPlanArea {
  id        String   @id @default(cuid())
  floorId   String
  unitId    String
  // JSON array of {x, y} percentage coordinates (0-100) for polygon vertices
  // e.g. [{"x":10,"y":20},{"x":30,"y":20},{"x":30,"y":40},{"x":10,"y":40}]
  polygon   String
  label     String?  // optional label displayed on the area
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor Floor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  unit  Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([floorId, unitId])
  @@index([floorId])
}

model BackupLog {
  id        String   @id @default(cuid())
  status    String
  filename  String?
  fileSize  BigInt?
  checksum  String?  // SHA-256 of the original .db file
  error     String?
  createdAt DateTime @default(now())
}

// TaskPriority: "LOW" | "MEDIUM" | "HIGH"
// TaskStatus:   "PENDING" | "IN_PROGRESS" | "COMPLETED" | "CANCELLED"
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  assignedTo  String    // User.id — sorumlu kişi
  createdById String    // User.id — oluşturan
  customerId  String?   // optional: bağlı müşteri
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignee  User      @relation("TaskAssignee",  fields: [assignedTo],  references: [id])
  creator   User      @relation("TaskCreator",   fields: [createdById], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}
